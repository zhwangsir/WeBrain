#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export SKILLHUB_HOME="${SKILLHUB_HOME:-$HOME/.webrain/skillhub}"
export SKILLHUB_INSTALL_ROOT="${SKILLHUB_INSTALL_ROOT:-$HOME/.webrain/skills}"
export OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_PATH:-$HOME/.webrain/webrain.json}"
export OPENCLAW_WORKSPACE_PATH="${OPENCLAW_WORKSPACE_PATH:-$HOME/.webrain/workspace}"
export OPENCLAW_PLUGIN_DIR="${OPENCLAW_PLUGIN_DIR:-$HOME/.webrain/extensions/skillhub}"

python3 "$SCRIPT_DIR/skills_store_cli.py" "$@"
