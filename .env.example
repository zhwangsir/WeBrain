# WeBrain Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# Sub Brain (Node.js Fastify)
# ============================================================
WEBRAIN_SUB_BRAIN_PORT=9797
WEBRAIN_EMBEDDED=1
WEBRAIN_PYTHON=python3

# Optional: Enable API Key authentication
# WEBRAIN_API_KEY=your-secret-api-key

# ============================================================
# Main Brain (Python FastAPI)
# ============================================================
WEBRAIN_MAIN_BRAIN_PORT=18790
WEBRAIN_MAIN_BRAIN_HOST=127.0.0.1

# ============================================================
# LLM Providers (at least one required)
# ============================================================
# Local LM Studio
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=minimax/minimax-m2.7

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-1.5-pro

# Ollama (local embedding)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# Optional Features
# ============================================================
# Stable Diffusion URL for image generation
SD_URL=http://localhost:7860

# Edge-TTS for text-to-speech
EDGE_TTS_ENABLED=false

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info
