# WineryClaw Gateway Configuration
# Copy this file to .env.local and customize for your environment

# Project directory (auto-detected, usually no need to change)
# WINERYCLAW_DIR=$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")

# Gateway port
WINERYCLAW_PORT=19001

# Node.js package manager (pnpm, npm, or bun)
WINERYCLAW_PM=pnpm

# Launch mode: background (no terminal) or terminal
WINERYCLAW_LAUNCH_MODE=background

# Auto-open browser on start
WINERYCLAW_AUTO_OPEN_BROWSER=true
