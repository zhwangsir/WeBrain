// Shared iOS signing defaults for local development + CI.
#include "Version.xcconfig"

WINERYCLAW_IOS_DEFAULT_TEAM = Y5PE65HELJ
WINERYCLAW_IOS_SELECTED_TEAM = $(WINERYCLAW_IOS_DEFAULT_TEAM)
WINERYCLAW_DEVELOPMENT_TEAM = $(WINERYCLAW_IOS_SELECTED_TEAM)
WINERYCLAW_CODE_SIGN_STYLE = Automatic
WINERYCLAW_APP_BUNDLE_ID = ai.openclaw.client
WINERYCLAW_WATCH_APP_BUNDLE_ID = ai.openclaw.client.watchkitapp
WINERYCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.openclaw.client.watchkitapp.extension
WINERYCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.openclaw.client.activitywidget
WINERYCLAW_WATCH_APP_PROFILE =
WINERYCLAW_WATCH_EXTENSION_PROFILE =

// Local contributors can override this by running scripts/ios-configure-signing.sh.
// Keep include after defaults: xcconfig is evaluated top-to-bottom.
#include? "../.local-signing.xcconfig"
#include? "../LocalSigning.xcconfig"

CODE_SIGN_STYLE = $(WINERYCLAW_CODE_SIGN_STYLE)
CODE_SIGN_IDENTITY = Apple Development
DEVELOPMENT_TEAM = $(WINERYCLAW_DEVELOPMENT_TEAM)

// Let Xcode manage provisioning for the selected local team unless a local override pins one.
PROVISIONING_PROFILE_SPECIFIER =
