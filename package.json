{
  "name": "@webrain/integration",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "cd frontend && pnpm exec eslint --fix",
      "cd frontend && pnpm exec prettier --write"
    ],
    "frontend/src/**/*.css": [
      "cd frontend && pnpm exec prettier --write"
    ]
  },
  "devDependencies": {
    "axios": "^1.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "vitest": "^1.6.0"
  }
}
